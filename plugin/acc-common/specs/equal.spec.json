    {"name": "out",   "io": "out", "dtype": ["bool"]}
  ],
  "generalize": true,
  "verify_mode": "exact",
  "precision": {"oracle": "ascendoptest", "threshold": 0,
                "threshold_source": "bool 逐元素严格一致（== 无容差）"},
  "perf": {"baseline": "tbe", "target_ratio": 0.95}
}
