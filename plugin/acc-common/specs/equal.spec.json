{
  "op": "Equal",
  "repo": "ops-math",
  "hardware": ["Atlas A2", "Atlas A3"],
  "reference": {"type": "tbe", "ref": "内置 TBE Equal (aclnnEqTensor)"},
  "change": {"kind": "align_dtype", "note": "与 TBE 对齐 dtype 集"},
  "params_source": "derived_from_reference",
  "params": [
    {"name": "self",  "io": "in",  "dtype": ["float32", "float16"]},
