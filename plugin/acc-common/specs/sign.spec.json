{
  "op": "Sign",
  "repo": "ops-math",
  "hardware": ["Atlas A2", "Atlas A3"],
  "reference": {"type": "tbe", "ref": "内置 TBE Sign", "path": "opp/built-in/... kernel/proto/config"},
  "change": {"kind": "add_dtype", "dtypes_added": ["int16"], "note": "与 TBE 全对齐所有 dtype + 加 int16"},
  "params_source": "derived_from_reference",
  "params": [
    {"name": "self", "io": "in",  "dtype": ["float32", "float16"], "noncontiguous": true},
    {"name": "out",  "io": "out", "dtype": ["float32", "float16"]}
  ],
  "generalize": true,
  "verify_mode": "numerical",
  "precision": {"oracle": "ascendoptest", "threshold": 0.001,
                "threshold_source": "AscendOpTest 默认阈值(fp16 1e-3)；sign 输出 ∈ {-1,0,1} 实为精确"},
  "perf": {"baseline": "tbe", "target_ratio": 1.0,
           "target_ratio_source": "任务书『相比原 TBE 性能无劣化』= 不劣化 = ratio ≥ 1.0（原写 0.95 偏松，2026-07-08 对齐任务书原文改正）",
           "small_shape_exception": {"text": "<10us 差 3us→仿真图", "when_us_below": 10,
                                     "abs_gap_us_within": 3, "requires": "simulation_plot+analysis"}}
}
